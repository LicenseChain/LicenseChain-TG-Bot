# Telegram Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_TOKEN=your-telegram-bot-token-here

# LicenseChain API Configuration
# Get your API key from https://dashboard.licensechain.app
LICENSE_CHAIN_API_KEY=your-licensechain-api-key-here
LICENSE_CHAIN_API_URL=https://api.licensechain.app

# Bot Configuration
# Port for health check server (default: 3005)
PORT=3005

# Logging Configuration
# Options: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Database Configuration
# SQLite database path (default: ./data/bot.db)
# For PostgreSQL/MySQL, use full connection string:
# DATABASE_URL=postgresql://user:password@localhost:5432/licensechain
# DATABASE_URL=mysql://user:password@localhost:3306/licensechain
DATABASE_URL=./data/bot.db

# Admin Configuration
# Comma-separated list of Telegram user IDs who have admin access
# Example: ADMIN_USERS=123456789,987654321
ADMIN_USERS=

# Optional: Webhook Configuration (if using webhooks instead of polling)
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
# WEBHOOK_SECRET=your-webhook-secret